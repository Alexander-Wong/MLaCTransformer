#!/bin/bash

# Prevent infinite loop on amend
if [ "$BUMPING_VERSION" = "1" ]; then
  exit 0
fi

# If pyproject.toml is already in this commit, skip
if git show --stat HEAD | grep -q "pyproject.toml"; then
  exit 0
fi

MSG=$(git log -1 --pretty=%B)
TYPE=$(echo "$MSG" | head -1 | grep -oE '^[a-z]+')
BREAKING=$(echo "$MSG" | grep -cE "(BREAKING CHANGE|^[a-z]+!:)" || true)

if [ "$BREAKING" -gt 0 ]; then
  BUMP="major"
elif [ "$TYPE" = "feat" ]; then
  BUMP="minor"
elif [ "$TYPE" = "fix" ]; then
  BUMP="patch"
else
  exit 0
fi

echo "→ Bumping version ($BUMP)..."
poetry version $BUMP

echo "→ Updating CHANGELOG.md..."
VERSION=$(poetry version --short)
DATETIME=$(date +"%Y-%m-%d %H:%M:%S")
DESC=$(echo "$MSG" | head -1 | sed 's/^[a-z]*([^)]*): //' | sed 's/^[a-z]*!*: //')
SCOPE=$(echo "$MSG" | head -1 | grep -oE '\([^)]+\)' | tr -d '()')

if [ -n "$SCOPE" ]; then
  ENTRY="## [$VERSION] - $DATETIME\n\n### $TYPE\n\n- **$SCOPE**: $DESC ($DATETIME)\n\n---\n\n"
else
  ENTRY="## [$VERSION] - $DATETIME\n\n### $TYPE\n\n- $DESC ($DATETIME)\n\n---\n\n"
fi

if [ -f CHANGELOG.md ]; then
  EXISTING=$(cat CHANGELOG.md)
  printf "%b%s" "$ENTRY" "$EXISTING" > CHANGELOG.md
else
  printf "%b" "$ENTRY" > CHANGELOG.md
fi

git add pyproject.toml CHANGELOG.md
BUMPING_VERSION=1 git commit --amend --no-edit
